# GigLift — Environment Variables
#
# Copy this file to `.env` and fill in real values.
#   cp .env.example .env
#
# Notes:
# - Variables prefixed with EXPO_PUBLIC_ are embedded in the client bundle
#   and are NOT secret. Never put private keys behind EXPO_PUBLIC_.

# App environment: development | staging | production
EXPO_PUBLIC_APP_ENV=development

# Supabase — required by the Supabase client (supabase/client.ts).
# Find these in your Supabase project: Settings -> API.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
